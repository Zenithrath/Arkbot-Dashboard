        "googleDriveOAuth2Api": { "id": "oKniVbvcRo8IJjd3", "name": "Google Drive account" }
      }
    },
    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst items = [];\n\nfunction flattenTree(node) {\n  if (node.id && node.mimeType !== 'application/vnd.google-apps.folder') {\n    items.push({ json: { id: node.id, name: node.name, mimeType: node.mimeType, parents: node.parents || [] } });\n  }\n  if (node.children && Array.isArray(node.children)) {\n    for (const child of node.children) {\n      flattenTree(child);\n    }\n  }\n}\n\nfor (const item of allItems) {\n  flattenTree(item.json);\n}\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [656, -80],
      "id": "d27b00a5",
      "name": "Flatten Tree"
    },
    {
      "parameters": {
        "url": "=https://www.googleapis.com/drive/v3/files/{{ $json.id }}?fields=id,name,mimeType,modifiedTime,size,parents",
