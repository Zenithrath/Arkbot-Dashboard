      "name": "List Folders Drive",
      "credentials": { "googleDriveOAuth2Api": { "id": "oKniVbvcRo8IJjd3", "name": "Google Drive account" } }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst extensions = ['.pdf','.docx','.xlsx','.doc','.xls','.pptx','.txt','.md','.csv','.jpg','.jpeg','.png','.gif','.zip','.rar'];\nconst folders = items\n  .filter(item => {\n    const name = (item.json.name || '').toLowerCase();\n    return !extensions.some(ext => name.endsWith(ext));\n  })\n  .map(item => ({ id: item.json.id, name: item.json.name, parents: item.json.parents || [] }));\nreturn [{ json: { folders } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [656, 180],
