      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst files = items.map(item => ({\n  id: item.json.id,\n  name: item.json.name,\n  mimeType: item.json.mimeType,\n  modifiedTime: item.json.modifiedTime || '',\n  size: item.json.size || '',\n  parents: item.json.parents || []\n}));\nreturn [{ json: { files } }];"
      },
