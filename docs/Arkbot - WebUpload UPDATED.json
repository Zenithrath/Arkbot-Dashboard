        "jsCode": "const SUPABASE_URL = 'https://msrcuijuqmfcfbvzlnjc.supabase.co';\nconst SERVICE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1zcmN1aWp1cW1mY2ZidnpsbmpjIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc2ODI4MDM4MCwiZXhwIjoyMDgzODU2MzgwfQ.BbqLOBsuByUbRF8MnfthdXjUkO_ef4GivGJEwqlSLuw';\n\nconst response = await this.helpers.httpRequest({\n  method: 'GET',\n  url: `${SUPABASE_URL}/rest/v1/process_lock?id=eq.1`,\n  headers: {\n    apikey: SERVICE_KEY,\n    Authorization: `Bearer ${SERVICE_KEY}`\n  }\n});\n\nconst rows = typeof response === 'string' ? JSON.parse(response) : response;\n\nreturn $input.all().map(item => ({\n  json: { ...item.json, is_locked: rows[0].is_locked },\n  binary: item.binary\n}));"
