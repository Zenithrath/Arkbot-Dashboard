    {
      "parameters": {
        "jsCode": "// ===== PERUBAHAN: Terima folder_id dari webhook =====\n// Folder mapping (lama) + dynamic folder_id dari webhook (baru)\n\nconst webhookBody = $('Webhook').item.json.body || {};\nconst folderIdFromRequest = webhookBody.folder_id;\n\nconst folderMap = {\n  'ArkBot - Library (Utama)': '1lKvWCa7FR23qRYL_mBGpQOhs6JI58sxj',\n  // Tambah folder mapping lain di sini jika perlu\n};\n\n// Prioritas: folder_id dari request > folder dari form > default\nlet targetFolderId = '1lKvWCa7FR23qRYL_mBGpQOhs6JI58sxj'; // default: Arkbot Library\n\nif (folderIdFromRequest) {\n  // Jika folder_id dikirim dari website, langsung pakai\n  targetFolderId = folderIdFromRequest;\n} else if (webhookBody.Folder) {\n  // Fallback ke folder mapping (backward compatible)\n  targetFolderId = folderMap[webhookBody.Folder] || targetFolderId;\n}\n\nreturn [{\n  json: {\n    ...$json,\n    targetFolderId: targetFolderId\n  },\n  binary: $binary\n}];"
      },
