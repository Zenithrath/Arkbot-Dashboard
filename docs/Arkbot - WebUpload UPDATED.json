        "jsCode": "const raw = $input.first().json;\nconst output = (raw.files && raw.files[0]) ? raw.files[0] : raw;\n\nconst text = output.text || output.content || output.plainText || output.markdown;\nif (text) {\n  return [{ json: { text, metadata: output.metadata || raw.metadata || {} } }];\n}\n\nif (output.sheets) {\n  let md = '';\n  for (const [sheetName, rows] of Object.entries(output.sheets)) {\n    if (!rows.length) continue;\n    const headerSet = new Set();\n    for (const row of rows) {\n      Object.keys(row).forEach(k => headerSet.add(k));\n    }\n    const headers = Array.from(headerSet).sort();\n    md += `## Sheet: ${sheetName}\\n\\n`;\n    md += `| ${headers.join(' | ')} |\\n| ${headers.map(() => '---').join(' | ')} |\\n`;\n    for (const row of rows) {\n      md += `| ${headers.map(h => row[h] ?? '').join(' | ')} |\\n`;\n    }\n    md += '\\n';\n  }\n  return [{ json: { text: md, metadata: output.metadata || raw.metadata || {} } }];\n}\n\nreturn [{ json: { text: JSON.stringify(output), metadata: output.metadata || raw.metadata || {}, _unrecognized_structure: true } }];"
      },
